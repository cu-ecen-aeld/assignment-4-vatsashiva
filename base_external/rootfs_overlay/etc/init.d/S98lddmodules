#!/bin/sh

case "$1" in
    start)
        echo "Loading LDD modules"

        if [ -x /usr/bin/scull_load ]; then
            /usr/bin/scull_load
        else
            modprobe scull || true
        fi

        if [ -x /usr/bin/module_load ]; then
            /usr/bin/module_load /usr/bin/faulty.ko
        else
            modprobe faulty || true
        fi

        modprobe hello || true
        ;;

    stop)
        echo "Unloading LDD modules"

        rmmod hello || true

        if [ -x /usr/bin/module_unload ]; then
            /usr/bin/module_unload faulty
        else
            rmmod faulty || true
        fi

        if [ -x /usr/bin/scull_unload ]; then
            /usr/bin/scull_unload
        else
            rmmod scull || true
            rmmod scullpipe || true
            rmmod scullsingle || true
            rmmod sculluid || true
        fi
        ;;

    restart)
        $0 stop
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
